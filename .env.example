# ProposalPilot Environment Configuration
# Copy this to .env and fill in your values

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_NAME=ProposalPilot AI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Public frontend deployment values (set these in Netlify/Vercel/Render Static Site)
# Example: VITE_API_BASE_URL=https://proposalpilot-api.onrender.com/api/v1
# Example: VITE_WS_BASE_URL=wss://proposalpilot-api.onrender.com
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
POSTGRES_USER=proposalpilot
POSTGRES_PASSWORD=proposalpilot_secret
POSTGRES_DB=proposalpilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://proposalpilot:proposalpilot_secret@localhost:5432/proposalpilot

# ─────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/1

# ─────────────────────────────────────────
# Qdrant Vector Database
# ─────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secret
QDRANT_COLLECTION_RFP=rfp_documents
QDRANT_COLLECTION_KB=internal_knowledge_base
QDRANT_COLLECTION_PROPOSALS=proposals

# ─────────────────────────────────────────
# LLM (Managed via llm_service.py)
# ─────────────────────────────────────────
# Set whichever provider you use:
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
GOOGLE_API_KEY=
GROQ_API_KEY=

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
RFP_ANALYSIS_MODEL=llama-3.3-70b-versatile
ARCHITECTURE_MODEL=openai/gpt-oss-120B
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=["pdf","docx","txt","md"]

# ─────────────────────────────────────────
# JWT Auth
# ─────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────
# Observability (Optional)
# ─────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=proposalpilot
LANGCHAIN_TRACING_V2=false
